# 服务运行端口 (云平台通常自动注入 PORT)
PORT=5000

# 浏览器类型 (可选: camoufox, chromium, chrome, msedge)
SOLVER_BROWSER=camoufox

# 浏览器并发数 (根据服务器内存调整，1核1G建议为 1)
SOLVER_THREADS=1

# 是否使用无头模式 (true/false)
SOLVER_HEADLESS=true

# 调试模式 (true/false)
SOLVER_DEBUG=false

# 节点身份 / 远程软初始化配置
# 生产必填：必须与注册端的 SOLVER_ADMIN_TOKEN 完全一致，否则注册端无法调用 /admin/reinitialize 对本节点执行远程自愈
SOLVER_NODE_ID=solver-01
SOLVER_NODE_LABEL=hk-b-01
SOLVER_ADMIN_TOKEN=change_me_shared_secret
SOLVER_REINIT_COOLDOWN_SECONDS=45
