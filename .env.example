# 服务运行端口 (云平台通常自动注入 PORT)
PORT=5000

# 浏览器类型 (可选: camoufox, chromium, chrome, msedge)
SOLVER_BROWSER=camoufox

# 浏览器并发数 (根据服务器内存调整，1核1G建议为 1)
SOLVER_THREADS=1

# 是否使用无头模式 (true/false)
SOLVER_HEADLESS=true

# 调试模式 (true/false)
SOLVER_DEBUG=false

# 节点身份 / 远程生命周期治理配置
# 生产必填：必须与注册端的 SOLVER_ADMIN_TOKEN 完全一致，否则注册端无法对本节点执行 drain / resume / lease / reinitialize 管理动作
SOLVER_NODE_ID=solver-01
SOLVER_NODE_LABEL=hk-b-01
SOLVER_ADMIN_TOKEN=change_me_shared_secret

# 远程软初始化（节点级自愈）
SOLVER_REINIT_COOLDOWN_SECONDS=45

# 空闲 / 待机 / 租约治理
SOLVER_IDLE_SOFT_RECYCLE_SECONDS=300
SOLVER_IDLE_STANDBY_SECONDS=900
SOLVER_LEASE_TTL_SECONDS=90
SOLVER_IDLE_SCAN_INTERVAL_SECONDS=15
SOLVER_STANDBY_AUTO_RESUME=true
